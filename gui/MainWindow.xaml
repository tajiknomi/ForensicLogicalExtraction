<Window x:Class="ForensicExtractorGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Android Forensic Extractor" Height="500" Width="600">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Devices -->
            <RowDefinition Height="*"/>
            <!-- Operations -->
            <RowDefinition Height="Auto"/>
            <!-- Proceed Button -->
            <RowDefinition Height="2*"/>
            <!-- Output -->
            <RowDefinition Height="Auto"/>
            <!-- Status -->
        </Grid.RowDefinitions>

        <!-- Connected Devices -->
        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
            <Label Content="Connected Devices:" VerticalAlignment="Center"/>
            <ComboBox x:Name="DevicesComboBox" Width="200" Margin="10,0,0,0"/>
            <Button x:Name="RefreshBtn" Content="Refresh" Margin="10,0,0,0" Width="75" Click="RefreshBtn_Click"/>
        </StackPanel>

        <!-- Operations Checkboxes -->
        <GroupBox Header="Select Operations" Grid.Row="1" Margin="0,0,0,10">
            <StackPanel>
                <CheckBox x:Name="ChkShowDevices" Content="Show Connected Devices"/>
                <CheckBox x:Name="ChkExtractDeviceInfo" Content="Extract Device Info"/>
                <CheckBox x:Name="ChkExtractApps" Content="Extract Installed Apps List"/>
                <CheckBox x:Name="ChkExtractMediaStore" Content="Extract MediaStore DB"/>
                <CheckBox x:Name="ChkExtractCallLogs" Content="Extract Call Logs"/>
                <CheckBox x:Name="ChkExtractSMS" Content="Extract SMS"/>
                <CheckBox x:Name="ChkPullMedia" Content="Pull Media"/>
                <CheckBox x:Name="ChkExtractCalendar" Content="Extract Calendar Entities"/>
            </StackPanel>
        </GroupBox>

        <!-- Proceed Button -->
        <Button x:Name="ProceedBtn" Content="Proceed" Grid.Row="2" Width="100" Height="30" HorizontalAlignment="Left" Click="ProceedBtn_Click"/>

        <!-- Output Pane -->
        <GroupBox Header="Output" Grid.Row="3" Margin="0,10,0,10">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBox x:Name="OutputTextBox" TextWrapping="Wrap" IsReadOnly="True" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
            </ScrollViewer>
        </GroupBox>

        <!-- Status -->
        <StackPanel Orientation="Horizontal" Grid.Row="4">
            <Label Content="Status:" VerticalAlignment="Center"/>
            <TextBlock x:Name="StatusText" Margin="10,0,0,0" VerticalAlignment="Center"/>
            <ProgressBar x:Name="ProgressBar" Width="200" Height="20" Margin="20,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>